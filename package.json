{
  "name": "apex-revenue-desktop",
  "version": "3.4.30",
  "description": "Apex Revenue Desktop — Creator Intelligence Engine + OBS Streaming Platform",
  "main": "main/main.js",
  "author": "Ridge Johnston",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "concurrently \"webpack serve --config webpack.renderer.js\" \"wait-on http://localhost:9000 && electron .\"",
    "start:prod": "webpack --config webpack.renderer.js --mode production && electron .",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:dir": "npm run build:renderer && electron-builder --dir --win",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1028.0",
    "@aws-sdk/client-cloudwatch": "^3.1028.0",
    "@aws-sdk/client-firehose": "^3.1028.0",
    "@aws-sdk/client-iot-data-plane": "^3.1028.0",
    "@aws-sdk/client-polly": "^3.1028.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/credential-providers": "^3.1028.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "js-yaml": "^4.1.1",
    "node-media-server": "^2.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@electron/packager": "^19.1.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  },
  "build": {
    "appId": "works.apexrevenue.desktop",
    "productName": "Apex Revenue",
    "copyright": "Copyright © 2025 Ridge Johnston",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/dist/**/*",
      "shared/**/*",
      "config/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "coach-knowledge-shipped/",
        "to": "coach-knowledge-shipped",
        "filter": [
          "**/*.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "ApexRevenue-${version}-${arch}.exe",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "portable": {
      "artifactName": "ApexRevenue-${version}-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Apex Revenue",
      "differentialPackage": false,
      "include": "build-resources/installer.nsh"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://apex-revenue-updates-994438967527.s3.amazonaws.com",
        "channel": "latest"
      }
    ],
    "forceCodeSigning": false
  }
}

{
  "name": "apex-revenue-desktop",
  "version": "2.0.9",
  "description": "Apex Revenue — Livestream Management Platform. Professional streaming with OBS integration, creator intelligence, real-time analytics, fan tracking, and monetization prompts.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "setup": "node scripts/setup-osn.js",
    "postinstall": "node scripts/setup-osn.js",
    "build": "node scripts/build-installer.js",
    "build:win": "node scripts/build-installer.js --win",
    "build:mac": "node scripts/build-installer.js --mac",
    "build:dir": "node scripts/build-installer.js --dir",
    "build:quick": "npx electron-builder --config electron-builder.config.js --dir"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "29.3.1",
    "electron-builder": "^24.9.1"
  },
  "author": "Ridge Johnston",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ridgejohnston/Apex-Revenue-Desktop.git"
  }
}
